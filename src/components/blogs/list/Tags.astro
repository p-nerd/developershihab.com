---
import type { Tag } from "@helpers/blogs.ts";
import { slugify } from "@helpers/slug.ts";
import { getCollection } from "astro:content";

interface Props {
    tags: Tag[];
    tagSlug?: string;
}

const { tags, tagSlug = "all" } = Astro.props as Props;

const blogs = await getCollection("blogs");

const tagsx = [{ label: "All", count: blogs.length }, ...tags];
---

<section class="flex flex-wrap justify-center gap-3">
    {
        tagsx.map(tag => (
            <a
                class={`flex cursor-pointer flex-col items-center rounded-xl border  px-4 py-2  dark:border-[#283043] ${
                    tagSlug === slugify(tag.label)
                        ? "bg-[#7611a6] text-white"
                        : "bg-[#F4F5F7] text-black dark:bg-[#131823] dark:text-white"
                }`}
                href={
                    tag.label === "All"
                        ? "/blogs/1"
                        : `/blogs/${slugify(tag.label)}`
                }
            >
                {tag.label} ({tag.count})
            </a>
        ))
    }
</section>
