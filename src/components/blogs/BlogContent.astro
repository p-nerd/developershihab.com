---
interface Props {
    Content: any;
    img: string;
    imgAlt: string;
}
const {Content, img, imgAlt} = Astro.props;
---

<main class="w-full max-w-[83rem] m-auto p-[1.5rem]">
    <div class="flex flex-col gap-[2.5rem] max-w-[90ch] m-auto">
        {img && <img src={img} alt={imgAlt || ''}/>}
        <article class="prose prose-zinc text-justify m-auto lg:prose-xl dark:prose-invert">
            <Content/>
        </article>
    </div>
</main>
