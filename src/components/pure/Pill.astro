---
interface Props {
    slug?: string;
}

const { slug } = Astro.props as Props;

const Tag = slug ? "a" : "button";
---

<Tag
    href={slug}
    class="pill flex py-2 px-4 gap-2 text-white border-solid border border-purple-700 bg-purple-700 rounded-full text-lg leading-[1.35] whitespace-nowrap"
>
    <slot />
</Tag>
