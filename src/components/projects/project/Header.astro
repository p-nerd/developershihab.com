---
import Hero from "../../pure/Hero.astro";
import Icon from "../../pure/Icon.astro";
import Pill from "../../projects/project/Pill.astro";

interface Props {
    technologies: string[];
    description: string;
    title: string;
    type: string;
}

const { technologies, description, title, type } = Astro.props;
---

<header
    class="w-auto border-b-[1px] border-solid border-[#e3e6ee] pb-[2.5rem] dark:border-[#283044]"
>
    <div
        class="flex w-full max-w-[83rem] flex-col gap-2"
        style="margin-inline: auto; padding-inline: 1.5rem;"
    >
        <div class="flex justify-between">
            <a
                class="hidden self-start underline decoration-transparent decoration-solid decoration-1 underline-offset-[0.25rem] hover:decoration-current focus:decoration-current lg:block"
                href="/projects"
            >
                <Icon icon="arrow-left" />
                <span>Projects</span>
            </a>
            <p class="text-2xl font-bold">{type}</p>
        </div>
        <Hero title={title} align="start">
            <div
                class="flex flex-col items-center justify-between gap-[1.5rem] p-[0.5rem] lg:flex-row lg:gap-[2.5rem]"
            >
                <p class="max-w-[54ch] text-[1.25rem]">{description}</p>
                <div class="flex w-full flex-wrap justify-end gap-[0.5rem]">
                    {technologies.map(t => <Pill>{t}</Pill>)}
                </div>
            </div>
        </Hero>
    </div>
</header>
