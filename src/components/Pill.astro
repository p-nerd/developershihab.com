---
interface Props {
    slug?: string;
}

const { slug } = Astro.props as Props;

const Tag = slug ? "a" : "button";
---

<Tag
    href={slug}
    class="pill flex gap-2 whitespace-nowrap rounded-full border border-solid border-purple-700 bg-purple-700 px-4 py-2 text-lg leading-[1.35] text-white"
>
    <slot />
</Tag>
