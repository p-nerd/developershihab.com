---
import { email } from "../../site.config";
import Icon from "./Icon.astro";
import CallToAction from "./CallToAction.astro";
---

<aside
    class="flex flex-col items-center gap-12 border-y border-solid border-[#e3e6ee] px-6 py-20 dark:border-[#283044] lg:flex-row lg:flex-wrap lg:justify-between lg:p-[7.5rem]"
>
    <h2
        class="max-w-[15ch] text-center text-[1.625rem] lg:text-left lg:text-[2.625rem]"
    >
        Interested in working together?
    </h2>
    <CallToAction href={`mailto:${email}`}>
        Send Me a Message
        <Icon icon="paper-plane-tilt" size="1.2em" />
    </CallToAction>
</aside>

<style>
    aside {
        background-color: var(--gray-999_40);
        box-shadow: var(--shadow-sm);
    }
</style>
