---
import { getCollection, type CollectionEntry } from "astro:content";

import ContactCTA from "@/components/ContactCTA";
import Layout from "@/layouts/Layout.astro";

import Header from "@/screens/blog/Header.astro";
import ContentBlog from "@/screens/blog/Content.astro";

export async function getStaticPaths() {
    const blogs = await getCollection("blogs");
    return blogs.map(entry => ({
        params: { slug: entry.slug },
        props: { entry },
    }));
}

interface Props {
    entry: CollectionEntry<"blogs">;
}

const { entry } = Astro.props;

const { Content } = await entry.render();
---

<Layout title={entry.data.title} description={entry.data.description}>
    <div class="flex flex-col gap-[5rem]">
        <div class="flex flex-col gap-[3.75rem]">
            <Header
                title={entry.data.title}
                description={entry.data.description}
                tags={entry.data.tags}
                publish_date={entry.data.publish_date}
            />
            <ContentBlog
                img={entry.data.img}
                img_alt={entry.data.img_alt || ""}
            >
                <Content />
            </ContentBlog>
        </div>
        <ContactCTA />
    </div>
</Layout>
 @/components/ContactCTA @/components/ContactCTA
