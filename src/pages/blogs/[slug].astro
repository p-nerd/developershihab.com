---
import { getCollection, type CollectionEntry } from "astro:content";

import ContactCTA from "@components/pure/ContactCTA.astro";
import Layout from "@layouts/Layout.astro";
import Header from "@components/blogs/blog/Header.astro";
import ContentBlog from "@components/blogs/blog/Content.astro";

export async function getStaticPaths() {
    const blogs = await getCollection("blogs");
    return blogs.map(entry => ({
        params: { slug: entry.slug },
        props: { entry },
    }));
}

interface Props {
    entry: CollectionEntry<"blogs">;
}

const { entry } = Astro.props;

const { Content } = await entry.render();
---

<Layout title={entry.data.title} description={entry.data.description}>
    <div class="flex flex-col gap-[5rem]">
        <div class="flex flex-col gap-[3.75rem]">
            <Header
                title={entry.data.title}
                description={entry.data.description}
                tags={entry.data.tags}
                publishDate={entry.data.publishDate}
            />
            <ContentBlog img={entry.data.img} imgAlt={entry.data.img_alt || ""}>
                <Content />
            </ContentBlog>
        </div>
        <ContactCTA />
    </div>
</Layout>
