---
import { titles, descriptions } from "site.config";
import { getCollection } from "astro:content";

import ContactCTA from "@components/ContactCTA.astro";
import Grid from "@components/Grid.astro";
import Hero from "@components/Hero.astro";
import Layout from "@layouts/Layout.astro";
import Preview from "@screens/blogs/index/Preview.astro";

const blogs = (await getCollection("blogs")).sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<Layout title={titles["/blogs"]} description={descriptions["/blogs"]}>
    <div class="flex flex-col gap-20">
        <main class="wrapper flex flex-col gap-8">
            <Hero
                title="My Blogs"
                tagline="Explore my Latest Insights and Perspectives"
                align="start"
                alignHero="end"
            />
            <Grid>
                {
                    blogs.map(blog => (
                        <Preview
                            slug={blog.slug}
                            publishDate={blog.data.publishDate}
                            imgAlt={blog.data.img_alt || ""}
                            img={blog.data.img}
                            title={blog.data.title}
                            description={blog.data.description}
                            tags={blog.data.tags}
                        />
                    ))
                }
            </Grid>
        </main>
        <ContactCTA />
    </div>
</Layout>
