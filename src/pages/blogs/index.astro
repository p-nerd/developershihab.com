---
import {getCollection} from "astro:content";
import {descriptions, titles} from "../../../site.config";
import BlogPage from "../../screens/blogs/index/BlogPage.astro";

const blogs = (await getCollection("blogs" as any)).sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BlogPage
        title={titles["/blogs"]}
        description={descriptions["/blogs"]}
        blogs={blogs}
/>

