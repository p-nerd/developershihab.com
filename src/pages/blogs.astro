---
import {getCollection} from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

import ContactCTA from "../components/partials/ContactCTA.astro";
import Hero from "../components/partials/Hero.astro";

import BlogGrid from "../components/blogs/BlogsGrid.astro";
import PreviewBlog from "../components/blogs/PreviewBlog";

import {descriptions, titles} from "../../site.config";

const blogs = (await getCollection("blogs")).sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout
        title={titles["/blogs"]}
        description={descriptions["/blogs"]}
>
    <div class="stack gap-20">
        <main class="wrapper stack gap-8">
            <!--suppress HtmlDeprecatedAttribute -->
            <Hero
                    title="My Blogs"
                    tagline="Explore my Latest Insights and Perspectives"
                    align="start"
                    alignHero="end"
            />
            <BlogGrid variant="offset">
                {
                    blogs.map((blog) => (
                            <PreviewBlog
                                    slug={blog.slug}
                                    publishDate={blog.data.publishDate}
                                    imgAlt={blog.data.img_alt}
                                    img={blog.data.img}
                                    title={blog.data.title}
                                    description={blog.data.description}
                                    tags={blog.data.tags}
                            />

                    ))
                }
            </BlogGrid>
        </main>
        <ContactCTA/>
    </div>
</BaseLayout>
