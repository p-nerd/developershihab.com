---
import { getCollection } from "astro:content";
import { titles, descriptions } from "site.config";

import Layout from "@layouts/Layout.astro";
import ContactCTA from "@components/pure/ContactCTA.astro";
import Hero from "@components/pure/Hero.astro";
import Grid from "@components/projects/list/Grid.astro";
import Preview from "@components/projects/list/Preview.astro";

const projects = (await getCollection("projects")).sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<Layout title={titles["/projects"]} description={descriptions["/projects"]}>
    <div class="flex flex-col gap-20">
        <main class="wrapper flex flex-col gap-8">
            <Hero
                title="My Projects"
                tagline="See my most recent projects below to get an idea of my past experience."
                align="start"
            />
            <Grid>
                {projects.map(project => <Preview project={project} />)}
            </Grid>
        </main>
        <ContactCTA />
    </div>
</Layout>
