---
import { getCollection } from "astro:content";
import { PROJECTS, type TProject } from "@/content/config";

import ContactCTA from "@/components/ContactCTA";
import Layout from "@/layouts/Layout.astro";
import Header from "@/screens/project/Header.tsx";
import ContentX from "@/screens/project/Content";

interface Props {
    entry: TProject;
}

export async function getStaticPaths() {
    const projects = await getCollection(PROJECTS);
    return projects.map(entry => ({
        params: { slug: entry.slug },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={entry.data.title} description={entry.data.description}>
    <div class="flex flex-col gap-[5rem]">
        <div class="flex flex-col gap-[3.75rem]">
            <Header project={entry} />
            <ContentX
                img={entry.data.img}
                img_alt={entry.data.img_alt || ""}
                imgLink={entry.data.img_link || ""}
            >
                <Content />
            </ContentX>
        </div>
        <ContactCTA />
    </div>
</Layout>
 @/components/ContactCTA @/components/ContactCTA
