---
import { getCollection } from "astro:content";

import ContactCTA from "@components/pure/ContactCTA.tsx";
import Layout from "@layouts/Layout.astro";
import Header from "@components/projects/ProjectHeader.tsx";
import ContentProject from "@components/projects/ProjectContent.tsx";
import { PROJECTS, type TProject } from "@content/config";

interface Props {
    entry: TProject;
}

export async function getStaticPaths() {
    const projects = await getCollection(PROJECTS);
    return projects.map(entry => ({
        params: { slug: entry.slug },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={entry.data.title} description={entry.data.description}>
    <div class="flex flex-col gap-[5rem]">
        <div class="flex flex-col gap-[3.75rem]">
            <Header project={entry} />
            <ContentProject
                img={entry.data.img}
                img_alt={entry.data.img_alt || ""}
                imgLink={entry.data.img_link || ""}
            >
                <Content />
            </ContentProject>
        </div>
        <ContactCTA />
    </div>
</Layout>
