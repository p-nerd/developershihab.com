---
import type { Page, PaginateFunction } from "astro";
import { titles, descriptions } from "site.config";
import { getCollection, type CollectionEntry } from "astro:content";

import ContactCTA from "@components/pure/ContactCTA.astro";
import Hero from "@components/pure/Hero.astro";
import Layout from "@layouts/Layout.astro";
import List from "@components/blogs/list/List.astro";
import PaginationLink from "@components/blogs/list/PaginationLink.astro";

export async function getStaticPaths({
    paginate,
}: {
    paginate: PaginateFunction;
}) {
    const blogs = (await getCollection("blogs")).sort(
        (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
    );
    return paginate(blogs, { pageSize: 4 });
}

export interface Props {
    page: Page<CollectionEntry<"blogs">>;
}

const { page } = Astro.props;

const blogs = page.data;

console.log(page);
---

<Layout title={titles["/blogs"]} description={descriptions["/blogs"]}>
    <div class="flex flex-col gap-20">
        <main class="wrapper flex flex-col gap-8">
            <Hero
                title="My Blogs"
                tagline="Explore my Latest Insights and Perspectives"
                align="start"
                alignHero="end"
            />
            <List blogs={blogs} />
            {
                page.url.next ? (
                    <PaginationLink link={page.url.next} />
                ) : (
                    <PaginationLink
                        link={page.url.prev}
                        text="Previous Blogs"
                    />
                )
            }
        </main>

        <ContactCTA />
    </div>
</Layout>
