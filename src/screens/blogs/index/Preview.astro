---
import { formatDateToMonthDayYear } from "@helpers/date.ts";

interface Props {
    slug: string;
    img: string;
    imgAlt: string;
    publishDate: Date;
    title: string;
    description: string;
    tags: string[];
}

const { slug, publishDate, imgAlt, img, title, description, tags } =
    Astro.props as Props;
---

<li>
    <a
        class="blog-card flex h-max flex-col gap-2 overflow-hidden rounded-xl border border-solid px-1 py-4 lg:rounded-3xl lg:p-5 lg:py-10"
        href={`/blogs/${slug}`}
    >
        <div class="lg:px-2 lg:py-1">
            <time
                class="blog-title m-2 rounded-md px-2 py-1 lg:rounded-2xl lg:px-4 lg:py-2"
                datetime="2023-06-19"
            >
                {formatDateToMonthDayYear(publishDate)}
            </time>
        </div>
        <div class="px-2 py-1 lg:px-4 lg:py-2">
            <img
                src={img}
                alt={imgAlt || ""}
                loading="lazy"
                decoding="async"
                class="h-full w-full rounded-xl object-contain"
            />
        </div>
        <div class="lg:px-2 lg:py-1">
            <h2
                class="blog-title m-2 rounded-md px-2 py-1 lg:rounded-2xl lg:px-4 lg:py-2"
            >
                {title}
            </h2>
        </div>
        <div class="lg:px-2 lg:py-1">
            <p
                class="blog-title m-2 rounded-md px-2 py-1 lg:rounded-2xl lg:px-4 lg:py-2"
            >
                {description}
            </p>
        </div>
        <div class="flex flex-wrap gap-2 px-2 py-1 lg:px-4 lg:py-2">
            {
                tags.map(tag => (
                    <span class="blog-title rounded-md px-2 py-1 lg:rounded-2xl lg:px-4 lg:py-2">
                        {tag}
                    </span>
                ))
            }
        </div>
    </a>
</li>

<style scoped>
    .blog-card {
        background: var(--gradient-subtle);
        border-color: var(--gray-800);
        box-shadow: var(--shadow-sm);
        font-family: var(--font-brand);
        font-size: var(--text-lg);
        transition: box-shadow var(--theme-transition);
    }

    .blog-card:hover {
        box-shadow: var(--shadow-md);
    }

    .blog-title {
        background: var(--gray-999);
        color: var(--gray-200);
    }
</style>
