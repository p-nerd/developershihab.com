{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "baseUrl": ".",
        "paths": {
            "@components/*": ["src/components/*"],
            "@content/*": ["src/content/*"],
            "@helpers/*": ["src/helpers/*"],
            "@layouts/*": ["src/layouts/*"],
            "@pages/*": ["src/pages/*"],
            "@partials/*": ["src/partials/*"],
            "@schemas/*": ["src/schemas/*"],
            "@screens/*": ["src/screens/*"],
            "@styles/*": ["src/styles/*"]
        }
    }
}
